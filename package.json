{
  "name": "task-management-api",
  "version": "1.0.0",
  "description": "RESTful task management API with PostgreSQL users, MongoDB tasks, and JWT authentication.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "check": "find src -name '*.js' -print0 | xargs -0 -n1 node --check",
    "frontend:dev": "vite --config frontend/vite.config.mjs",
    "frontend:build": "vite build --config frontend/vite.config.mjs"
  },
  "keywords": [
    "express",
    "postgresql",
    "mongodb",
    "jwt",
    "task-management"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "morgan": "^1.10.0",
    "pg": "^8.13.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "nodemon": "^3.1.4",
    "vite": "^8.0.10"
  }
}
